# PocketBase
POCKETBASE_URL=http://127.0.0.1:8090

# PocketBase Admin (superuser credentials)
PB_ADMIN_EMAIL=your_admin_email@example.com
PB_ADMIN_PASS=your_admin_password

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenRouter (AI pipeline — https://openrouter.ai)
OpenRouter_API_KEY=sk-or-v1-your_openrouter_api_key

# Email (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
NEXT_PUBLIC_STRIPE_PRICE_ID_GROWTH=price_your_growth_price_id
NEXT_PUBLIC_STRIPE_PRICE_ID_SCALE=price_your_scale_price_id
